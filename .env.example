# quantlab environment configuration — COPY to .env and fill in real values.
#
# WARNING: Never commit real API keys. .env is gitignored; keep it that way.
# These are placeholders only.

TIINGO_API_KEY=your-tiingo-api-key-here
ALPACA_API_KEY=your-alpaca-api-key-here
ALPACA_SECRET_KEY=your-alpaca-secret-key-here

# Paper trading endpoint ONLY. Live endpoints (api.alpaca.markets without the
# "paper-" prefix) are rejected at load time by the safety gate in config.py.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional email alerting. The EmailChannel is ACTIVE only when ALL five of these
# are set; otherwise alerts still go to the console and reports/alerts/alerts.jsonl.
# SMTP_PASS is never logged. Uncomment and fill in to enable email alerts.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=your-smtp-password-here
# ALERT_EMAIL_TO=you@example.com
